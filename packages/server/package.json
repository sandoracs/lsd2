{
  "name": "@lsd2/server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --platform node --out-dir dist",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@lsd2/color-mapping": "workspace:*",
    "@lsd2/protocol": "workspace:*",
    "express": "^4.18.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
